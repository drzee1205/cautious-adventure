{
  "name": "nelson-gpt",
  "version": "1.0.0",
  "description": "AI-powered pediatric medical assistant with ChatGPT interface",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:staging": "tsc && vite build --mode staging",
    "build:production": "tsc && vite build --mode production",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "docker:build": "docker build -t nelson-gpt .",
    "docker:run": "docker run -p 3000:80 nelson-gpt",
    "docker:dev": "docker-compose --profile dev up",
    "docker:prod": "docker-compose --profile production up",
    "deploy:staging": "npm run build:staging && echo 'Deploy to staging'",
    "deploy:production": "npm run build:production && echo 'Deploy to production'",
    "security:audit": "npm audit --audit-level moderate",
    "analyze:bundle": "npm run build && npx vite-bundle-analyzer",
    "generate:icons": "node scripts/generate-icons.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^9.0.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "framer-motion": "^10.0.0",
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^7.9.3",
    "react-router-dom": "^6.26.0",
    "react-syntax-highlighter": "^15.0.0",
    "uuid": "^9.0.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-syntax-highlighter": "^15.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^0.19.0",
    "vitest": "^1.0.0",
    "workbox-window": "^7.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
